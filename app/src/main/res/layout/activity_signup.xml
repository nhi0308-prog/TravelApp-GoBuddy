<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F6F6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- LOGO -->
        <ImageView
            android:layout_width="180dp"
            android:layout_height="80dp"
            android:layout_marginTop="28dp"
            android:src="@drawable/gobuddylogo"
            android:scaleType="fitCenter" />

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginTop="18dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign up to start your journey"
            android:textSize="14sp"
            android:textColor="#777777"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp" />

        <!-- CARD FORM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_signup_card"
            android:padding="18dp">

            <!-- LAST NAME -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="@drawable/bg_input">

                <TextView
                    android:layout_width="26dp"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/edtLastName"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Họ"
                    android:textSize="14sp"
                    android:inputType="textPersonName"
                    android:background="@android:color/transparent" />

            </LinearLayout>

            <!-- FIRST NAME -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="@drawable/bg_input">

                <TextView
                    android:layout_width="26dp"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/edtFirstName"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Tên"
                    android:textSize="14sp"
                    android:inputType="textPersonName"
                    android:background="@android:color/transparent" />

            </LinearLayout>

            <!-- BIRTHDAY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="@drawable/bg_input">

                <TextView
                    android:layout_width="26dp"
                    android:layout_height="wrap_content"
                    android:text="🎂"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/edtBirthday"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Ngày tháng năm sinh"
                    android:textSize="14sp"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:background="@android:color/transparent" />

            </LinearLayout>

            <!-- EMAIL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="@drawable/bg_input">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_email" />

                <EditText
                    android:id="@+id/edtSignupEmail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:hint="Email"
                    android:textSize="14sp"
                    android:inputType="textEmailAddress"
                    android:background="@android:color/transparent" />

            </LinearLayout>

            <!-- ADDRESS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="@drawable/bg_input">

                <TextView
                    android:layout_width="26dp"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/edtAddress"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Địa chỉ"
                    android:textSize="14sp"
                    android:inputType="textPostalAddress"
                    android:background="@android:color/transparent" />

            </LinearLayout>

            <!-- PASSWORD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="@drawable/bg_input">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_lock" />

                <EditText
                    android:id="@+id/edtSignupPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="8dp"
                    android:hint="Mật khẩu"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:inputType="textPassword"
                    android:background="@android:color/transparent" />

                <ImageView
                    android:id="@+id/btnSignupEye"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_eye"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- BUTTON -->
            <Button
                android:id="@+id/btnCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="22dp"
                android:text="Create Account"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_button" />

        </LinearLayout>

        <!-- BACK TO LOGIN -->
        <TextView
            android:id="@+id/txtBackLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an account? Log In"
            android:textColor="#FF5722"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

</ScrollView>